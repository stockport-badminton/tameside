<%- include('header.ejs') %>
<%- include('nav.ejs') %>


  <% if (typeof errors !== 'undefined') { %>
    <p>Something seems to have gone wrong</p>
    <p><%= error %></p>
  <% }
  else { %>
    <h1><%= fullName %></h1>
    <% if (result && result.length > 0) { %>
    <div class="card mb-4">
      <div class="card-body p-2" style="position:relative;height:400px;">
        <canvas id="elo-chart"></canvas>
      </div>
    </div>
    <% } %>
    <div class="table-responsive">
    <table class="table" id="results-table">
      <thead>
        <tr>
          <th>date</th>
          <th>Partner</th>
          <th>Opponent 1</th>
          <th>Opponent 2</th>
          <th>points for</th>
          <th>points against</th>
          <th>type</th>
          <th>rating before</th>
          <th>rating after</th>
          <th>adjustment</th>
        </tr>
      </thead>
      <tbody>
    <% result.forEach(function(row){ %>
      <%
        var MyDate = new Date(row['date']);
        var MyDateString;

        // MyDate.setDate(MyDate.getDate() + 20);

        MyDateString = ('0' + MyDate.getDate()).slice(-2) + '/'
                     + ('0' + (MyDate.getMonth()+1)).slice(-2) + '/'
                     + MyDate.getFullYear();
      %>

      <tr>

          <td><%= MyDateString %></td>
          <td><%= row['partnerName'] %></td>
          <td><%= row['oppName1'] %></td>
          <td><%= row['oppName2'] %></td>
          <td><%= row['score'] %></td>
          <td><%= row['vsScore'] %></td>
          <td><%= row['gameType'] %></td>
          <td><%= row['before'] %></td>
          <td><%= row['after'] %></td>
          <td><%= row['adjustment'] %></td>
      </tr>
    <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <td></td>
          <td></td>
          <td></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>
   <% } %>




<% if (typeof errors === 'undefined' && result && result.length > 0) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
<script>
  (function() {
    var allPoints = <%- JSON.stringify(
      result.slice().reverse()
        .filter(function(r){ return r.after && r.after > 0 })
        .map(function(r){
          return {
            x: new Date(r.date).toISOString().slice(0,10),
            y: r.after,
            tip: (r.partnerName || '') + ' vs ' + (r.oppName1 || '') + ' / ' + (r.oppName2 || '') +
                 '  (' + r.score + '–' + r.vsScore + ')  ' +
                 (r.adjustment > 0 ? '+' : '') + r.adjustment
          }
        })
    ) %>;

    // One point per fixture date: keep the last game played that night so the
    // chart shows a clean "end-of-fixture rating" trend rather than per-game zigzags.
    var byDate = {};
    allPoints.forEach(function(pt) { byDate[pt.x] = pt; });
    var raw = Object.keys(byDate).sort().map(function(k) { return byDate[k]; });

    new Chart(document.getElementById('elo-chart'), {
      type: 'line',
      data: {
        datasets: [{
          label: <%- JSON.stringify(fullName + ' ELO') %>,
          data: raw,
          borderColor: '#007bff',
          backgroundColor: 'rgba(0,123,255,0.08)',
          fill: true,
          tension: 0,
          pointRadius: 3,
          pointHoverRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            type: 'time',
            time: { unit: 'month', tooltipFormat: 'dd MMM yyyy' },
            title: { display: false }
          },
          y: {
            title: { display: true, text: 'ELO Rating' }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                return 'Rating: ' + ctx.raw.y + '  |  ' + ctx.raw.tip;
              }
            }
          }
        }
      }
    });
  })();
</script>
<% } %>

<%- include('footer.ejs') %>
<%- include('datatables.ejs') %>

</body>
</html>
