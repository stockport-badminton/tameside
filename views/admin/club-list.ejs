<%- include('../header.ejs') %>
<%- include('../nav.ejs') %>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0"><i class="fas fa-users"></i> Club Admin</h1>
    <a class="btn btn-primary" href="/admin/clubs/create"><i class="fas fa-plus"></i> Add Club</a>
  </div>

  <% var _clubs = (typeof clubs !== 'undefined' && clubs) ? clubs : []; %>
  <div class="table-responsive">
    <table class="table table-striped align-middle">
      <thead>
        <tr><th scope="col">Club</th><th scope="col" class="text-end">Actions</th></tr>
      </thead>
      <tbody>
        <% _clubs.forEach(function(c) { %>
        <tr>
          <th scope="row"><%= c.name %></th>
          <td class="text-end"><a class="btn btn-sm btn-outline-secondary" href="/admin/clubs/<%= c.id %>">Edit</a></td>
        </tr>
        <% }); %>
        <% if (!_clubs.length) { %><tr><td colspan="2">No clubs yet.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../footer.ejs') %>

</body>
</html>
