<%- include('../header.ejs') %>
<%- include('../nav.ejs') %>

<%
  var galleryTag = '';
  settings.forEach(function(s){ if (s.key === 'homepage_gallery_tag') galleryTag = s.value; });
%>

<div class="col-12">
  <h1>Site Settings</h1>
  <p><a href="/admin/homepage-content">Homepage Content</a></p>

  <form method="post" action="/admin/site-settings">
    <div class="mb-3">
      <label class="form-label" for="homepage_gallery_tag">Gallery Cloudinary Tag</label>
      <input type="text" class="form-control" id="homepage_gallery_tag" name="homepage_gallery_tag" value="<%= galleryTag %>">
      <small class="form-text text-muted">The Cloudinary asset tag used to fetch homepage gallery photos (e.g. "messer2024"). Note: the gallery is not currently displayed on the site — this is reserved for a future gallery feature.</small>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
</div>

<%- include('../footer.ejs') %>
