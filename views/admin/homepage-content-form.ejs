<%- include('../header.ejs') %>
<%- include('../nav.ejs') %>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<div class="col-12">
  <h1><%= announcement ? 'Edit' : 'New' %> Announcement</h1>

  <form method="post" action="<%= announcement ? '/admin/homepage-content/' + announcement.id : '/admin/homepage-content' %>">
    <div class="mb-3">
      <label class="form-label" for="title">Title</label>
      <input type="text" class="form-control" id="title" name="title" value="<%= announcement ? announcement.title : '' %>" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Teaser (shown in the homepage News feed)</label>
      <div id="teaser-editor" style="background:#fff;"><%- announcement ? announcement.teaser_html : '' %></div>
      <textarea name="teaser_html" id="teaser_html" style="display:none;"></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label">Modal body (optional — if filled in, a "Read more" link appears after the teaser)</label>
      <div id="modal-editor" style="background:#fff;"><%- announcement && announcement.modal_body_html ? announcement.modal_body_html : '' %></div>
      <textarea name="modal_body_html" id="modal_body_html" style="display:none;"></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label" for="image_url">Image URL (shown in the modal — paste a link to an existing hosted image)</label>
      <input type="text" class="form-control" id="image_url" name="image_url" value="<%= announcement && announcement.image_url ? announcement.image_url : '' %>">
    </div>

    <div class="mb-3">
      <label class="form-label" for="sort_order">Sort order (lower shows first)</label>
      <input type="number" class="form-control" id="sort_order" name="sort_order" value="<%= announcement ? announcement.sort_order : 0 %>">
    </div>

    <div class="mb-3 form-check">
      <input type="checkbox" class="form-check-input" id="active" name="active" <%= !announcement || announcement.active ? 'checked' : '' %>>
      <label class="form-check-label" for="active">Active (visible on homepage)</label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/admin/homepage-content" class="btn btn-secondary">Cancel</a>
  </form>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script>
  var teaserQuill = new Quill('#teaser-editor', { theme: 'snow' });
  var modalQuill = new Quill('#modal-editor', { theme: 'snow' });

  document.querySelector('form').addEventListener('submit', function() {
    document.getElementById('teaser_html').value = teaserQuill.root.innerHTML;
    document.getElementById('modal_body_html').value = modalQuill.getText().trim().length ? modalQuill.root.innerHTML : '';
  });
</script>

<%- include('../footer.ejs') %>
