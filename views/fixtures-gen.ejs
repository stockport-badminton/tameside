<%- include('header.ejs') %>
<%- include('nav.ejs') %>

<div class="container-fluid mt-3">

<% if (flash) { %>
<div class="alert alert-success alert-dismissible fade show" role="alert">
  <%= flash %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
  <div>
    <h1 class="mb-0">Fixture Generator — <%= seasonDates.season.slice(0,4) %>/<%= seasonDates.season.slice(4) %></h1>
    <small class="text-muted">
      Season: <%= seasonDates.start %> → <%= seasonDates.end %> &nbsp;|&nbsp;
      Easter: <%= seasonDates.easter %> &nbsp;|&nbsp;
      <% if (isDraft) { %>
        Loaded from saved draft
        <% if (generatedAt) { %>(generated <%= new Date(generatedAt).toLocaleDateString('en-GB') %>)<% } %>
      <% } else { %>
        Freshly generated &amp; saved as draft
      <% } %>
    </small>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <form method="POST" action="/fixture-gen/regenerate" style="display:inline">
      <button class="btn btn-warning btn-sm" onclick="return confirm('Regenerate? This will replace the current draft.')">
        Regenerate
      </button>
    </form>
    <form method="POST" action="/fixture-gen/publish" style="display:inline">
      <button class="btn btn-danger btn-sm" onclick="return confirm('Publish to live fixture schedule? This will overwrite any unplayed fixtures for this season.')">
        Publish to Season
      </button>
    </form>
    <button id="dlSpreadsheet" class="btn btn-success btn-sm">Download Spreadsheet</button>
  </div>
</div>

<% if (typeof stats !== 'undefined' && stats) { %>
<div class="card mb-3">
  <div class="card-body">
    <div class="row g-3 text-center mb-3">
      <div class="col-6 col-md-3">
        <div class="fw-bold fs-4"><%= stats.totalFixtures %></div>
        <small class="text-muted">Fixtures scheduled</small>
      </div>
      <div class="col-6 col-md-3">
        <div class="fw-bold fs-4"><%= stats.datesUsed %></div>
        <small class="text-muted">Dates used</small>
      </div>
      <div class="col-6 col-md-3">
        <% if (stats.extensions !== null) { %>
          <div class="fw-bold fs-4 <%= stats.extensions > 0 ? 'text-warning' : 'text-success' %>"><%= stats.extensions %></div>
        <% } else { %>
          <div class="fw-bold fs-4 text-muted">—</div>
        <% } %>
        <small class="text-muted">Season extensions</small>
      </div>
      <div class="col-6 col-md-3">
        <% if (stats.unplaced !== null) { %>
          <div class="fw-bold fs-4 <%= stats.unplaced > 0 ? 'text-danger' : 'text-success' %>"><%= stats.unplaced %></div>
        <% } else { %>
          <div class="fw-bold fs-4 text-muted">—</div>
        <% } %>
        <small class="text-muted">Unplaced fixtures</small>
      </div>
    </div>
    <h6 class="text-muted mb-2">Consecutive nights per club</h6>
    <% if (stats.consecutiveNights && stats.consecutiveNights.length > 0) { %>
      <div class="d-flex flex-wrap gap-2">
        <% stats.consecutiveNights.forEach(function(cn) { %>
          <span class="badge <%= cn.count > 2 ? 'bg-danger' : cn.count > 1 ? 'bg-warning text-dark' : 'bg-secondary' %>">
            <%= cn.club %>: <%= cn.count %>
          </span>
        <% }) %>
      </div>
    <% } else { %>
      <span class="text-success small">No consecutive nights for any club.</span>
    <% } %>
  </div>
</div>
<% } %>

<% if (typeof qfPermutations !== 'undefined' && qfPermutations.length > 0) { %>
<%
  // Build lookup: "homeId-awayId" → scheduled date string for QF perms
  var qfScheduled = {};
  if (typeof fixturesOutput !== 'undefined') {
    fixturesOutput.forEach(function(row) {
      (row.fixtures || []).forEach(function(f) {
        if (f.lewisQF) qfScheduled[f.homeTeam.id + '-' + f.awayTeam.id] = row.dbDate;
      });
    });
  }
%>
<div class="card mb-3">
  <div class="card-header fw-bold" style="background:#fce5c0">Lewis Shield QF Permutations</div>
  <div class="card-body p-2">
    <p class="small text-muted mb-2">All possible QF matchups are scheduled (★ with date). Actual fixture played depends on R1/R2 results.</p>
    <div class="row g-2">
      <% qfPermutations.forEach(function(slot) { %>
      <div class="col-12 col-md-6 col-lg-3">
        <div class="small fw-bold mb-1">QF slot <%= slot.qfDrawPos %></div>
        <% slot.pairs.forEach(function(p) {
             var key = p.homeTeamId + '-' + p.awayTeamId;
             var date = qfScheduled[key];
        %>
          <div class="small <%= date ? 'fw-semibold' : 'text-muted' %>">
            <%= date ? '★ ' : '· ' %><%= teamNamesById[p.homeTeamId] || p.homeTeamId %> v <%= teamNamesById[p.awayTeamId] || p.awayTeamId %><% if (date) { %> <span class="text-muted fw-normal">(<%= date %>)</span><% } %>
          </div>
        <% }) %>
      </div>
      <% }) %>
    </div>
  </div>
</div>
<% } %>

<% if (typeof fixturesOutput !== 'undefined') { %>
<div class="table-responsive mb-4">
  <table class="table table-sm table-striped" id="results-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Home Team</th>
        <th>Away Team</th>
        <th>Division</th>
      </tr>
    </thead>
    <tbody>
      <% fixturesOutput.forEach(function(dateRow){ %>
        <% if (typeof dateRow.fixtures !== 'undefined') { dateRow.fixtures.forEach(function(fixture){ %>
        <tr>
          <td><%= dateRow.date %></td>
          <td><%= fixture.homeTeam.name %></td>
          <td><%= fixture.awayTeam.name %></td>
          <td><%= fixture.division %></td>
        </tr>
        <% }) } %>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<% divData.forEach(function(div, idx) { %>
<hr />
<h2><%= div.name %></h2>
<div id="divOutput_<%= idx %>"></div>
<% }) %>

</div>

<%- include('footer.ejs') %>
<%- include('datatables.ejs') %>

<script>
    var seasonDates = <%- JSON.stringify(seasonDates) %>;
    var xmasDate      = new Date(seasonDates.xmas);
    var easterDate    = new Date(seasonDates.easter);
    var seasonStart   = new Date(seasonDates.start);
    var seasonEnd     = new Date(seasonDates.calendarEnd || seasonDates.end);

    var nearEaster = function(d) {
        var s = new Date(+easterDate); s.setDate(easterDate.getDate() - 4);
        var e = new Date(+easterDate); e.setDate(easterDate.getDate() + 2);
        return d > s && d < e;
    };

    var nearXmas = function(d) {
        var s = new Date(+xmasDate); s.setDate(xmasDate.getDate() - xmasDate.getDay());
        var e = new Date(+s); e.setDate(s.getDate() + 14);
        return d >= s && d <= e;
    };

    var lewisR1Start   = new Date(seasonDates.lewisR1Start);
    var lewisR1End     = new Date(seasonDates.lewisR1End);
    var lewisR2Start   = new Date(seasonDates.lewisR2Start);
    var lewisR2End     = new Date(seasonDates.lewisR2End);
    var lewisQFStart   = new Date(seasonDates.lewisQFStart);
    var lewisQFEnd     = new Date(seasonDates.lewisQFEnd);
    function lewisWindowStyle(d) {
        if (d >= lewisR1Start && d <= lewisR1End) return "background:#ddeeff";
        if (d >= lewisR2Start && d <= lewisR2End) return "background:#c0d8f8";
        if (d >= lewisQFStart && d <= lewisQFEnd) return "background:#b4c7e7";
        return "";
    }
    // Fixture-based lewis style — uses the flag on the fixture object (more accurate than window-based
    // since QF fixtures may be scheduled outside the Easter window)
    function fixtureLewisStyle(fix) {
        if (fix.lewisQF) return "background:#fce5c0";
        if (fix.lewisR2) return "background:#c0d8f8";
        if (fix.lewisR1) return "background:#ddeeff";
        return "";
    }
    function fixtureXlsStyle(fix, isHome) {
        var base = isHome ? 'Bold' : 'Ital';
        if (fix.lewisQF) return 'LewisQF';
        if (fix.lewisR2) return 'LewisR2';
        if (fix.lewisR1) return 'LewisR1';
        return base;
    }

    function buildDivisionTables(fixtures, divisionTeams, startDate) {
        var weekdays = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
        var html = "<table border='1' cellpadding='4' cellspacing='0'>\n";

        // 3 header rows
        for (var i = 0; i < 3; i++) {
            var row = [(i === 2 ? "Match day" : " "), " "];
            for (var k in divisionTeams) {
                if (i === 0) row.push(" ");
                else if (i === 1) row.push(divisionTeams[k].name);
                else row.push(divisionTeams[k].homeNight);
            }
            html += "<tr><td>" + row.join("</td><td>") + "</td></tr>\n";
        }

        var day = new Date(startDate);
        while (day <= seasonEnd) {
            var lewisStyle = lewisWindowStyle(day);
            var dateLabel = day.getDate() + "/" + (day.getMonth()+1) + "/" + day.getFullYear();
            if (lewisStyle) dateLabel += " ★";
            var row = [weekdays[day.getDay()], dateLabel];
            for (var k in divisionTeams) {
                if (nearXmas(day)) {
                    row.push(day.getDay() === 3 ? "XMAS BREAK" : "X");
                } else if (nearEaster(day)) {
                    row.push(day.getDay() === 3 ? "EASTER BREAK" : "X");
                } else {
                    var dd = day.getFullYear() + '-' + String(day.getMonth()+1).padStart(2,'0') + '-' + String(day.getDate()).padStart(2,'0');
                    var tf = fixtures.filter(function(f) { return f.date === dd; });
                    var cellVal = " ";
                    for (var j = 0; j < tf.length; j++) {
                        var fStyle = fixtureLewisStyle(tf[j]);
                        if (tf[j].homeTeam === divisionTeams[k].name) { cellVal = fStyle ? "<span style='" + fStyle + ";display:block'><strong>" + tf[j].homeTeam + "</strong></span>" : "<strong>" + tf[j].homeTeam + "</strong>"; break; }
                        if (tf[j].awayTeam === divisionTeams[k].name) { cellVal = fStyle ? "<span style='" + fStyle + ";display:block'><em>" + tf[j].awayTeam + "</em></span>" : "<em>" + tf[j].awayTeam + "</em>"; break; }
                    }
                    row.push(cellVal);
                }
            }
            html += "<tr><td>" + row.join("</td><td>") + "</td></tr>\n";
            day.setDate(day.getDate() + 1);
        }
        html += "</table>\n";

        // Cross-reference grid
        var grid = "<table border='1' cellpadding='4' cellspacing='0'>\n<tr><td>&nbsp;</td>";
        for (var k in divisionTeams) grid += "<td>" + divisionTeams[k].name + "</td>";
        grid += "</tr>\n";
        for (var hk in divisionTeams) {
            grid += "<tr><td>" + divisionTeams[hk].name + "</td>";
            for (var ak in divisionTeams) {
                if (hk === ak) {
                    grid += "<td>&nbsp;</td>";
                } else {
                    var match = fixtures.filter(function(f) { return f.homeTeam === divisionTeams[hk].name && f.awayTeam === divisionTeams[ak].name; });
                    grid += match.length
                        ? "<td>" + match[0].date.replace(/^(\d{4})-(\d{2})-(\d{2})$/, "$3/$2/$1") + "</td>"
                        : "<td>0/0/0000</td>";
                }
            }
            grid += "</tr>\n";
        }
        grid += "</table>";

        return { html: html, grid: grid };
    }

    // Render each division's tables into the page
    var divData = <%- JSON.stringify(divData) %>;
    var allDivFixtures = [];
    var allDivTeams    = [];

    divData.forEach(function(div, idx) {
        var fixtures = JSON.parse(div.fixtures);
        var teams    = JSON.parse(div.teams);
        allDivFixtures.push(fixtures);
        allDivTeams.push(teams);
        var result = buildDivisionTables(fixtures, teams, seasonStart);
        document.getElementById('divOutput_' + idx).innerHTML = result.html + result.grid;
    });

    // ── Spreadsheet download (real XLSX via write-excel-file, 2 tabs per division) ─

    function buildXlsxSheets(allDivFixtures, allDivTeams) {
        var weekdays = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
        var sheetData  = [];
        var sheetNames = [];

        divData.forEach(function(div, idx) {
            var fixtures = allDivFixtures[idx];
            var teams    = allDivTeams[idx];
            var keys     = Object.keys(teams);

            // ── Calendar sheet ───────────────────────────────────────────────
            var calRows = [];

            var hdrRow = [{ value: '' }, { value: '' }];
            keys.forEach(function(k) {
                hdrRow.push({ value: teams[k].name, fontWeight: 'bold', color: '#FFFFFF', backgroundColor: '#4472C4' });
            });
            calRows.push(hdrRow);

            var subRow = [{ value: '' }, { value: 'Home night', fontStyle: 'italic' }];
            keys.forEach(function(k) {
                subRow.push({ value: teams[k].homeNight, fontStyle: 'italic', backgroundColor: '#D9E1F2' });
            });
            calRows.push(subRow);

            var day = new Date(seasonStart);
            while (day <= seasonEnd) {
                var row = [
                    { value: weekdays[day.getDay()] },
                    { value: day.getDate() + '/' + (day.getMonth()+1) + '/' + day.getFullYear() }
                ];
                keys.forEach(function(k) {
                    var tn = teams[k].name;
                    if (nearXmas(day)) {
                        row.push({ value: day.getDay() === 3 ? 'XMAS BREAK' : 'X', fontWeight: 'bold', backgroundColor: '#FFE699' });
                    } else if (nearEaster(day)) {
                        row.push({ value: day.getDay() === 3 ? 'EASTER BREAK' : 'X', fontWeight: 'bold', backgroundColor: '#FFE699' });
                    } else {
                        var dd = day.getFullYear() + '-' + String(day.getMonth()+1).padStart(2,'0') + '-' + String(day.getDate()).padStart(2,'0');
                        var tf = fixtures.filter(function(f){ return f.date === dd; });
                        var cell = { value: '' };
                        for (var i = 0; i < tf.length; i++) {
                            if (tf[i].homeTeam === tn || tf[i].awayTeam === tn) {
                                var isHome = tf[i].homeTeam === tn;
                                cell = { value: tn };
                                if      (tf[i].lewisQF) { cell.backgroundColor = '#FCE5C0'; cell.fontWeight = 'bold'; }
                                else if (tf[i].lewisR2) { cell.backgroundColor = '#C0D8F8'; cell.fontWeight = 'bold'; }
                                else if (tf[i].lewisR1) { cell.backgroundColor = '#DDEEFF'; cell.fontWeight = 'bold'; }
                                else if (isHome)        { cell.fontWeight = 'bold'; }
                                else                    { cell.fontStyle  = 'italic'; }
                                break;
                            }
                        }
                        row.push(cell);
                    }
                });
                calRows.push(row);
                day.setDate(day.getDate() + 1);
            }

            sheetData.push(calRows);
            sheetNames.push(div.name + ' Cal');

            // ── Grid sheet ───────────────────────────────────────────────────
            var gridRows = [];
            var gHdr = [{ value: '' }];
            keys.forEach(function(k) {
                gHdr.push({ value: teams[k].name, fontWeight: 'bold', color: '#FFFFFF', backgroundColor: '#4472C4' });
            });
            gridRows.push(gHdr);

            keys.forEach(function(hk) {
                var gRow = [{ value: teams[hk].name, fontWeight: 'bold', color: '#FFFFFF', backgroundColor: '#4472C4' }];
                keys.forEach(function(ak) {
                    if (hk === ak) { gRow.push({ value: '-' }); return; }
                    var m = fixtures.filter(function(f){ return f.homeTeam === teams[hk].name && f.awayTeam === teams[ak].name; });
                    gRow.push({ value: m.length ? m[0].date.replace(/^(\d{4})-(\d{2})-(\d{2})$/,'$3/$2/$1') : '' });
                });
                gridRows.push(gRow);
            });

            sheetData.push(gridRows);
            sheetNames.push(div.name + ' Grid');
        });

        return { sheetData: sheetData, sheetNames: sheetNames };
    }

    document.getElementById('dlSpreadsheet').addEventListener('click', function() {
        var season = seasonDates.season;
        function doDownload() {
            var built = buildXlsxSheets(allDivFixtures, allDivTeams);
            window.writeXlsxFile(built.sheetData, {
                sheets: built.sheetNames,
                fileName: 'tameside-fixtures-' + season + '.xlsx'
            }).catch(function(e) { console.error('XLSX export failed:', e); });
        }
        if (typeof window.writeXlsxFile !== 'undefined') {
            doDownload();
        } else {
            var s = document.createElement('script');
            s.src = 'https://cdn.jsdelivr.net/npm/write-excel-file@1/bundle/write-excel-file.min.js';
            s.onload = doDownload;
            document.head.appendChild(s);
        }
    });
</script>

</body>
</html>
