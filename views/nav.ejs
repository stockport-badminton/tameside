                                <a class="dropdown-item" href="/admin/lewis">Lewis Results</a>
                                <a class="dropdown-item" href="/admin/scorecard-ocr">Scorecard OCR</a>
                                <a class="dropdown-item" href="/admin/distribution">Distribution Lists</a>
                            <% } else if(locals.user._json['https://my-app.example.com/role'] == 'admin') { %>
                                <a class="dropdown-item" href="/manage-players/club-<%= locals.user._json['https://my-app.example.com/club'] %>">Team Players</a>
                                <a class="dropdown-item" href="/static/docs/Team Registration.pdf" target="_blank">Team Registration (blank)</a>
                                <a class="dropdown-item" href="/forms/team-registration/<%= locals.user._json['https://my-app.example.com/club'] %>/prefilled" target="_blank">Team Registration (prefilled)</a>
