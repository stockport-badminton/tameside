<!-- expand-xl (not lg): the navbar is position:sticky via modern-styles.css, so
     it's in document flow — an expanded menu wider than the viewport widens the
     whole page and causes horizontal scrolling. Collapse below 1200px instead. -->
<nav class="navbar navbar-expand-xl navbar-dark fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <i class="fas fa-shuttle-badminton"></i> Tameside Badminton League
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavDropdown">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-trophy"></i> Fixtures & Results
