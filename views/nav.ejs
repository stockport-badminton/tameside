                        <li><a class="dropdown-item" href="/history">All seasons &amp; documents</a></li>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link" href="/lewis-shield"><i class="fas fa-shield-halved"></i> Lewis Shield</a></li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-file-lines"></i> Useful Files
                    </a>
