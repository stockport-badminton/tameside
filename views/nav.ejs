                        <li><a class="dropdown-item" href="/static/docs/scorecard.pdf"><i class="fas fa-file-pdf"></i> Scorecard</a></li>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link" href="/rules"><i class="fas fa-book"></i> Rules</a></li>
                <li class="nav-item"><a class="nav-link" href="/contact-us"><i class="fas fa-envelope"></i> Contact</a></li>
                <% if(locals.user) { %>
                    <li class="nav-item dropdown">
