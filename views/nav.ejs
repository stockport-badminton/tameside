                        <li><a class="dropdown-item" href="/tables/All"><i class="fas fa-table"></i> Tables</a></li>
                        <li><a class="dropdown-item" href="/results/All"><i class="fas fa-list"></i> All</a></li>
                        <li><a class="dropdown-item" href="/results/Division 1">Division 1</a></li>
                        <li><a class="dropdown-item" href="/results/Division 2">Division 2</a></li>
                        <% if(locals.user) { %>
                        <li><a class="dropdown-item" href="/elo-chart"><i class="fas fa-chart-line"></i> Ratings</a></li>
                        <% } %>
                    </ul>
                </li>
                <li class="nav-item"><a class="nav-link" href="/info/clubs"><i class="fas fa-users"></i> Clubs</a></li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-clock-rotate-left"></i> History
                    </a>
                    <ul class="dropdown-menu">
                        <% var _past = (typeof pastSeasons !== 'undefined' && pastSeasons) ? pastSeasons : []; %>
                        <% _past.slice(0, 4).forEach(function(s) { var label = s.name.slice(0,4) + '/' + s.name.slice(4); %>
                        <li><a class="dropdown-item" href="/tables/All/<%= s.name %>"><%= label %> Tables</a></li>
                        <li><a class="dropdown-item" href="/results/All/<%= s.name %>"><%= label %> Results</a></li>
