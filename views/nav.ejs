                                    <a class="dropdown-item" href="/player-stats">Individual Stats</a>
                                    <a class="dropdown-item" href="/pair-stats">Pair Stats</a>
                                <% } %>
                            <% } %>
                            <a class="dropdown-item" href="/logout" target="_blank">Logout</a>
                        </div>
                    </li>
                <% } else { %>
                    <li class="nav-item"><a class="nav-link" href="/login"><i class="fas fa-right-to-bracket"></i> Log in</a></li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<main role="main" class="container">
